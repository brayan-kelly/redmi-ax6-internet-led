#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

NAME="internet-led"
SCRIPT="/usr/bin/internet-led.sh"
PIDFILE="/var/run/internet-led.pid"
LOG_TAG="internet-led"

start_service() {
    local enabled
    config_load internet-led
    config_get_bool enabled main enabled 1
    [ "$enabled" -eq 0 ] && return 0

    if [ ! -x "$SCRIPT" ]; then
        logger -t "$LOG_TAG" "ERROR: Script not found or not executable"
        return 1
    fi

    logger -t "$LOG_TAG" "Starting service"

    procd_open_instance
    procd_set_param command "$SCRIPT"
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile "$PIDFILE"
    procd_close_instance
}

stop_service() {
    logger -t "$LOG_TAG" "Stopping service"
    if [ -f "$SCRIPT" ]; then
        "$SCRIPT" stop
    fi
    rm -f /tmp/internet_led_state "$PIDFILE" 2>/dev/null
}

reload_service() {
    logger -t "$LOG_TAG" "Reloading service"
    stop
    start
}

service_triggers() {
    procd_add_reload_trigger "network"
}
